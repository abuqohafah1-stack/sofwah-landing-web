# ── SOFWAH-WEB · environment template ──────────────────────────────────────
# Copy to .env on the server (Forge does this) and fill the blanks.
# NEVER commit the real .env.

APP_NAME="Sofwah Arabic Grill"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://sofwaharabicgrill.com   # <- set the real domain (canonical/OG/sitemap follow this)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (MySQL 8) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sofwah_web
DB_USERNAME=forge
DB_PASSWORD=

# ── Cache / queue / session (Redis) ──
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (for future lead notifications) ──
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@sofwaharabicgrill.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sofwah-specific (see config/sofwah.php) ──
GA4_ID=                       # G-XXXXXXXXXX — leave blank to keep analytics off
GOOGLE_MAPS_KEY=              # only if live Google reviews / geo sync is enabled later
WHATSAPP_ORDER_DEFAULT=60142288956   # fallback order number (per-branch in resources/content/branches.php)
